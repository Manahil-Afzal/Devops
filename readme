# 🚀 NODE.JS DEPLOYMENT ON AWS EC2 (UBUNTU + PM2 + NGINX)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 🧭 PROJECT OVERVIEW
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

This project demonstrates how to deploy a **Node.js + Express application** on an **AWS EC2 Ubuntu server** using a traditional production setup.

### 🔧 Technologies Used
- Ubuntu Server
- Node.js
- Express.js
- PM2 Process Manager
- Nginx Reverse Proxy
- AWS EC2 Security Groups

---

# 🖥️ 1. CONNECT TO EC2 INSTANCE
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

```bash
ssh -i "EC2.pem" ubuntu@<EC2-PUBLIC-IP>
```

---

# 📦 2. UPDATE SYSTEM PACKAGES
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

```bash
sudo apt update && sudo apt upgrade -y
```

---

# 🟢 3. INSTALL NODE.JS & NPM
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

```bash
sudo apt install nodejs npm -y
```

### ✅ Check Versions
```bash
node -v
npm -v
```

---

# 📁 4. SETUP PROJECT DIRECTORY
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

```bash
mkdir Devops
cd Devops
```

### OR (Using Git)
```bash
git clone <repo-url>
cd <project-folder>
```

---

# 📦 5. INSTALL DEPENDENCIES
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

```bash
npm install
```

---

# ⚙️ 6. CREATE EXPRESS SERVER
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

### 📄 Create File
```bash
nano server.js
```

### 💻 Add Code
```javascript
const express = require("express");
const app = express();

app.get("/", (req, res) => {
    res.send("Server running on EC2");
});

app.listen(3000, "0.0.0.0", () => {
    console.log("Server running on port 3000");
});
```

---

# 🚀 7. INSTALL PM2 (PROCESS MANAGER)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

```bash
sudo npm install -g pm2
pm2 start server.js
```

### 📊 Monitor Application
```bash
pm2 list
pm2 logs
```

---

# 🔥 8. INSTALL NGINX
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

```bash
sudo apt install nginx -y
```

### Check Status
```bash
systemctl status nginx
```

---

# ⚙️ 9. CONFIGURE NGINX (REVERSE PROXY)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

```bash
sudo nano /etc/nginx/sites-available/default
```

### Replace with:
```nginx
location / {
    proxy_pass http://localhost:3000;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection 'upgrade';
    proxy_set_header Host $host;
    proxy_cache_bypass $http_upgrade;
}
```

### Apply Changes
```bash
sudo nginx -t
sudo systemctl restart nginx
```

---

# 🌐 10. AWS SECURITY GROUP SETTINGS
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

| TYPE  | PORT | SOURCE     |
|------|------|------------|
| SSH  | 22   | YOUR IP    |
| HTTP | 80   | 0.0.0.0/0  |

---

# 🌍 11. ACCESS APPLICATION
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

### Direct Node.js
```
http://<EC2-IP>:3000
```

### Nginx (Recommended)
```
http://<EC2-IP>
```

---

# 🔁 12. RESTART SERVICES
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

```bash
pm2 restart all
sudo systemctl restart nginx
```

---

# 📊 13. MONITORING COMMANDS
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

```bash
pm2 logs
pm2 list
sudo ss -tulpn | grep 3000
```

---

# 📁 14. BASIC LINUX COMMANDS
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

```bash
pwd
ls
ls -la
cd folder
mkdir folder
rm -rf folder
clear
```

---

# 📄 15. FILE OPERATIONS
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

```bash
touch file.txt
nano file.txt
cat file.txt
cp file1 file2
mv file1 file2
```

---

# 🧠 ARCHITECTURE FLOW
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

```
Browser → Nginx (Port 80) → Node.js (Port 3000) → PM2
```

---

# ⚠️ COMMON ISSUES & FIXES
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

### ❌ Site not opening
- Check AWS Security Group (port 80 / 3000)

### ❌ Nginx error
```bash
sudo nginx -t
```

### ❌ Node not running
```bash
pm2 list
```

